#!/usr/bin/env bash

FLAKE="github:moreauadrien/flakes"

update() {
  echo "Updating flake..."
  nix flake update --flake $FLAKE
  echo "✓ Flake updated."
}

init() {
  template=$(
    nix flake show "$FLAKE" --json 2>/dev/null \
      | jq -r '.templates | to_entries[] | "\(.key)\t\(.value.description // "")"' \
      | fzf --with-nth=1 --preview 'echo {2}' --delimiter='\t' \
            --prompt="Template > " \
      | cut -f1
  )

  [[ -z "$template" ]] && exit 0

  nix flake init -t "${FLAKE}#${template}"
  echo "✓ Template '$template' copied."

  nix develop
}

case "${1}" in
  update) update ;;
  *)      init   ;;
esac
